{
  "build": {
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "scripts/build_frontend_for_tauri.sh",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "CSV Align",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ],
    "longDescription": "A modern application to compare CSV files with visual difference highlighting, filtering, and export capabilities.",
    "shortDescription": "CSV File Comparison Tool",
    "linux": {
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    },
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null
    }
  },
  "productName": "CSV Align",
  "mainBinaryName": "csv-align",
  "identifier": "com.csvalign.desktop",
  "version": "2.1.57"
}
