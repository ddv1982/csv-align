{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-capability",
  "description": "Default desktop capability for app commands and file dialogs",
  "windows": ["main", "app-*"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "dialog:allow-open",
    "dialog:allow-save"
  ]
}
